          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "turns"
          }
        ]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "dependencies\n| where name startswith \"invoke_agent\"\n| extend raw_cd = tostring(column_ifexists(\"customDimensions\", \"\"))\n| extend raw_props = tostring(column_ifexists(\"Properties\", \"\"))\n| extend bag = coalesce(parse_json(raw_cd), parse_json(raw_props))\n| extend agent = coalesce(tostring(bag[\"gen_ai.agent.name\"]), \"unknown-agent\")\n| summarize turns = count(), last_seen = max(timestamp) by trace_id = operation_Id, agent\n| order by turns desc\n| take 50",
            "resources": [
              "${appi_resource}"
            ],
            "resultFormat": "table"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A",
          "subscription": "${subscription}"
        }
      ],
      "title": "Sessions: turn count and conversation count (top 50)",
      "type": "table"
    }
