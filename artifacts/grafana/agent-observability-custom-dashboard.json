              {
                "color": "green"
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "azureLogAnalytics": {
            "query": "dependencies\n| where name startswith \"invoke_agent\"\n| extend raw_cd = tostring(column_ifexists(\"customDimensions\", \"\"))\n| extend raw_props = tostring(column_ifexists(\"Properties\", \"\"))\n| extend bag = coalesce(parse_json(raw_cd), parse_json(raw_props))\n| extend agent = coalesce(tostring(bag[\"gen_ai.agent.name\"]), \"unknown-agent\")\n| extend ok = iff(tobool(column_ifexists(\"success\", column_ifexists(\"Success\", \"false\"))) == true, \"success\", \"error\")\n| summarize n = count() by bin(timestamp, $__interval), agent, ok\n| order by timestamp asc",
            "resources": [
              "${appi_resource}"
            ],
            "resultFormat": "time_series"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A",
          "subscription": "${subscription}"
        }
      ],
      "title": "Agent run rate (stacked, by agent and outcome)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${ds_azmon}"
      },
      "fieldConfig": {
