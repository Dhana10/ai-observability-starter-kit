            RT["Red Team\n3 strategies"]
        end

        OTel --> CE
        OTel --> BE
        OTel --> RT

        subgraph Output["Alerts + Dashboards"]
            direction TB
            AL["Scheduled Query Alerts\nerror count · p95 latency"]
            DA["App Insights Agents Pane\nGrafana · Custom JSON"]
        end

        CE --> AL
        BE --> DA
        RT --> DA
        CE --> DA
    end

