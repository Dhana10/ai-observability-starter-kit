graph LR
    subgraph Foundry["Microsoft Foundry Project"]
        direction LR

        subgraph Models["Model Deployments"]
            direction TB
            M1["gpt-4o-mini\n(primary)"]
            M2["gpt-5-mini\n(comparison)"]
            M3["gpt-4.1-mini\n(comparison)"]
        end

